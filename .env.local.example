# ─────────────────────────────────────────
# Supabase Credentials
# ─────────────────────────────────────────
# Find these at: Supabase Dashboard → Settings → API

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─────────────────────────────────────────
# Direct Database Connection
# ─────────────────────────────────────────
# Find this at: Supabase Dashboard → Settings → Database → Connection string
# Used by the FastAPI backend for direct DB queries
# NOTE: All tables live in the "pathersaathi" schema, not "public".
#       Set search_path in your connection or use fully qualified names:
#       e.g. SELECT * FROM pathersaathi.vehicles;

DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres?options=-csearch_path%3Dpathersaathi
